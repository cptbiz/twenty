# =============================================================================
# Twenty CRM - Railway Environment Variables
# =============================================================================

# =============================================================================
# Core Application Settings
# =============================================================================
APP_SECRET=your_32_character_random_secret_here_change_me
NODE_ENV=production
PORT=3000

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Railway automatically provides DATABASE_URL for PostgreSQL service
# You don't need to set these manually if using Railway's PostgreSQL addon
# DATABASE_URL=postgresql://username:password@host:port/database

# =============================================================================
# Redis Configuration
# =============================================================================
# Railway automatically provides REDIS_URL for Redis service
# You don't need to set these manually if using Railway's Redis addon
# REDIS_URL=redis://host:port

# =============================================================================
# URL Configuration
# =============================================================================
# Railway automatically provides RAILWAY_STATIC_URL
# These will be set automatically by the startup scripts
# SERVER_URL=${RAILWAY_STATIC_URL}
# FRONT_BASE_URL=${RAILWAY_STATIC_URL}

# =============================================================================
# Storage Configuration (Optional)
# =============================================================================
# For local storage (default)
STORAGE_TYPE=local

# For S3-compatible storage (recommended for production)
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_NAME=your-bucket-name
# STORAGE_S3_ENDPOINT=https://your-s3-endpoint.com

# =============================================================================
# Authentication Providers (Optional)
# =============================================================================
# Google OAuth
# AUTH_GOOGLE_CLIENT_ID=your_google_client_id
# AUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
# AUTH_GOOGLE_CALLBACK_URL=${RAILWAY_STATIC_URL}/auth/google/callback
# AUTH_GOOGLE_APIS_CALLBACK_URL=${RAILWAY_STATIC_URL}/auth/google-apis/callback
# MESSAGING_PROVIDER_GMAIL_ENABLED=true
# CALENDAR_PROVIDER_GOOGLE_ENABLED=true

# Microsoft OAuth
# AUTH_MICROSOFT_CLIENT_ID=your_microsoft_client_id
# AUTH_MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# AUTH_MICROSOFT_CALLBACK_URL=${RAILWAY_STATIC_URL}/auth/microsoft/callback
# AUTH_MICROSOFT_APIS_CALLBACK_URL=${RAILWAY_STATIC_URL}/auth/microsoft-apis/callback
# AUTH_MICROSOFT_ENABLED=true
# CALENDAR_PROVIDER_MICROSOFT_ENABLED=true
# MESSAGING_PROVIDER_MICROSOFT_ENABLED=true

# =============================================================================
# Email Configuration (Optional)
# =============================================================================
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME="Your Company Name"
# EMAIL_SYSTEM_ADDRESS=system@yourdomain.com
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your_email@gmail.com
# EMAIL_SMTP_PASSWORD=your_app_password

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
# DISABLE_DB_MIGRATIONS=false
# DISABLE_CRON_JOBS_REGISTRATION=false